generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  MODERATOR
}

enum Type {
  RECEIPT
  SALE
  TRANSFER
  WRITE_OFF
}

enum Status {
  DRAFT
  COMPLETED
  CANCELLED
}

model User {
  id String @id @default(cuid())
  email String @unique
  password String
  role Role @default(USER)
  refreshToken String?
  expiredAt BigInt?
}

model Warehouse {
  id String @id @default(cuid())
  code String @unique
  address String
  lines InventoryDocumentLine[]
  transactions InventoryTransaction[]
  balances InventoryBalance[]
}

model Product {
  id String @id @default(cuid())
  sku String @unique
  name String
  prices Price[]
  lines InventoryDocumentLine[]
  transactions InventoryTransaction[]
  balances InventoryBalance[]
}

model Price {
  id String @id @default(cuid())
  amount Decimal
  validFrom DateTime @default(now())
  validTo DateTime?
  product Product @relation(fields: [productId], references: [id])
  productId String
}

model InventoryDocument {
  id String @id @default(cuid())
  type Type @default(SALE)
  status Status @default(DRAFT)
  createdAt DateTime @default(now())
  lines InventoryDocumentLine[]
  transactions InventoryTransaction[]
}

model InventoryDocumentLine {
  id String @id @default(cuid())
  quantity Int
  price Decimal
  document InventoryDocument @relation(fields: [documentId], references: [id])
  documentId String
  product Product @relation(fields: [productId], references: [id])
  productId String
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  warehouseId String
}

model InventoryTransaction {
  id String @id @default(cuid())
  quantity Int
  price Decimal
  document InventoryDocument @relation(fields: [documentId], references: [id])
  documentId String
  product Product @relation(fields: [productId], references: [id])
  productId String
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  warehouseId String
}

model InventoryBalance {
  id String @id @default(cuid())
  quantity Int
  product Product @relation(fields: [productId], references: [id])
  productId String @unique
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  warehouseId String @unique
}